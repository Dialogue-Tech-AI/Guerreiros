# ============================================================
# AI Worker - Variáveis de ambiente (PRODUÇÃO)
# ============================================================
# ============================================================

# SQS (produção)
USE_SQS=true
AWS_REGION=us-east-1
SQS_QUEUE_AI_MESSAGES_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-ai-messages
SQS_QUEUE_AI_RESPONSES_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-ai-responses
SQS_QUEUE_FUNCTION_CALL_PROCESS_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-function-call-process
SQS_QUEUE_FUNCTION_CALL_RESPONSE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-function-call-response

# PostgreSQL (RDS)
POSTGRES_URL=postgresql://altese:senha-prod@seu-endpoint-rds.amazonaws.com:5432/altese_autopecas

# Redis (ElastiCache)
REDIS_HOST=seu-endpoint-redis.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Qdrant (container qdrant na EC2)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# OpenAI
OPENAI_API_KEY=sua-openai-key-prod
OPENAI_MODEL=gpt-4o-mini

# Node.js API (backend)
NODE_API_URL=http://app:3000
INTERNAL_API_KEY=internal-key-prod

# Custos
USD_BRL_RATE=5.5

# Logging
LOG_LEVEL=INFO
