# ============================================================
# Backend - Variáveis de ambiente (PRODUÇÃO)
# ============================================================
# Copie para backend.env
# Para o docker-compose, execute: --env-file config/server/credentials/backend.env
# As variáveis sem sufixo _PROD são usadas na substituição do compose.
# ============================================================

IS_PRODUCTION=true

# Substituição no docker-compose (duplicar valores de _PROD)
DB_HOST=seu-endpoint-rds.amazonaws.com
DB_PORT=5432
DB_USER=altese
DB_PASSWORD=senha-prod
DB_NAME=altese_autopecas
REDIS_HOST=seu-endpoint-redis.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
AWS_REGION=us-east-1
POSTGRES_URL=postgresql://altese:senha-prod@seu-endpoint-rds.amazonaws.com:5432/altese_autopecas

# Application
APP_PORT_PROD=3000
APP_NAME_PROD=Altese Autopeças

# Database (RDS)
DB_HOST_PROD=seu-endpoint-rds.amazonaws.com
DB_PORT_PROD=5432
DB_USER_PROD=altese
DB_PASSWORD_PROD=senha-prod
DB_NAME_PROD=altese_autopecas
DB_SYNC_PROD=false
DB_LOGGING_PROD=false
DB_SSL_PROD=true

# Redis (ElastiCache)
REDIS_HOST_PROD=seu-endpoint-redis.amazonaws.com
REDIS_PORT_PROD=6379
REDIS_PASSWORD_PROD=
REDIS_DB_PROD=0

# RabbitMQ (pode ser local na EC2 ou SQS)
RABBITMQ_HOST_PROD=localhost
RABBITMQ_PORT_PROD=5672
RABBITMQ_USER_PROD=guest
RABBITMQ_PASS_PROD=senha-prod
RABBITMQ_VHOST_PROD=/
RABBITMQ_QUEUE_MESSAGES_PROD=altese-messages
RABBITMQ_QUEUE_AI_PROD=altese-ai-requests
RABBITMQ_QUEUE_NOTIFICATIONS_PROD=altese-notifications

# MinIO / Storage (S3 em prod)
USE_AWS_STORAGE=true
USE_AWS_QUEUE=true
USE_AWS_CACHE=false
AWS_REGION_PROD=us-east-1
S3_BUCKET_MEDIA_PROD=altese-media-ACCOUNT
S3_BUCKET_ATTACHMENTS_PROD=altese-attachments-ACCOUNT
S3_BUCKET_LOGS_PROD=altese-logs-ACCOUNT
SQS_QUEUE_AI_MESSAGES_URL_PROD=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-ai-messages
SQS_QUEUE_AI_RESPONSES_URL_PROD=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-ai-responses
SQS_QUEUE_FUNCTION_CALL_PROCESS_URL_PROD=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-function-call-process
SQS_QUEUE_FUNCTION_CALL_RESPONSE_URL_PROD=https://sqs.us-east-1.amazonaws.com/ACCOUNT/altese-function-call-response

# Fallback MinIO (se não usar S3)
MINIO_ENDPOINT_PROD=localhost
MINIO_PORT_PROD=9000
MINIO_USE_SSL_PROD=false
MINIO_ACCESS_KEY_PROD=minio-prod
MINIO_SECRET_KEY_PROD=minio-secret-prod
MINIO_BUCKET_ATTACHMENTS_PROD=attachments
MINIO_BUCKET_MEDIA_PROD=media

# JWT
JWT_SECRET_PROD=jwt-secret-prod
JWT_EXPIRES_IN_PROD=1d
JWT_REFRESH_EXPIRES_IN_PROD=7d

# OpenAI
OPENAI_API_KEY_PROD=sua-openai-key-prod
OPENAI_TEMPERATURE_PROD=0.7
OPENAI_MAX_TOKENS_PROD=1000
OPENAI_TIMEOUT_PROD=30000

# Internal API / Qdrant
INTERNAL_API_KEY_PROD=internal-key-prod
QDRANT_PORT_PROD=6333

# WhatsApp
WHATSAPP_META_ACCESS_TOKEN_PROD=token-prod
WHATSAPP_META_VERIFY_TOKEN_PROD=verify-prod

# Security / CORS
CORS_ORIGIN_PROD=https://seu-dominio.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Config
ATTENDANCE_INACTIVE_TIMEOUT=86400000
ATTENDANCE_CONTEXT_RETENTION_DAYS=7
AI_CONTEXT_TTL=604800
ROUTING_STRATEGY=round-robin
AFFINITY_RETENTION_DAYS=90
