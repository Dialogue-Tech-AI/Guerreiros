# ============================================================
# Frontend - Variáveis de ambiente (PRODUÇÃO)
# ============================================================
# Usado no build Docker (ARG VITE_API_URL). Em prod atrás do Nginx,
# o frontend usa caminho relativo /api para o proxy.
# ============================================================

# URL base da API (geralmente /api quando atrás de Nginx proxy)
VITE_API_URL=/api
