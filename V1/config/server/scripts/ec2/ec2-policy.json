{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage"
      ],
      "Resource": "arn:aws:ecr:us-east-1:264263332458:repository/altese-*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage",
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": [
        "arn:aws:sqs:us-east-1:264263332458:altese-ai-messages",
        "arn:aws:sqs:us-east-1:264263332458:altese-ai-responses",
        "arn:aws:sqs:us-east-1:264263332458:altese-function-call-process",
        "arn:aws:sqs:us-east-1:264263332458:altese-function-call-response"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::altese-media-264263332458/*",
        "arn:aws:s3:::altese-attachments-264263332458/*"
      ]
    }
  ]
}
