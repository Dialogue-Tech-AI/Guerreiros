# ============================================================
# Backend - Variáveis de ambiente (DESENVOLVIMENTO)
# ============================================================
# Copie para backend.env: copy backend.env-exemple backend.env
# ============================================================

IS_PRODUCTION=false

# Application
APP_PORT_DEV=3000
APP_NAME_DEV=Altese Autopeças

# Database
DB_HOST_DEV=localhost
DB_PORT_DEV=5432
DB_USER_DEV=altese
DB_PASSWORD_DEV=senha-dev
DB_NAME_DEV=altese_autopecas
DB_SYNC_DEV=false
DB_LOGGING_DEV=false
DB_SSL_DEV=false

# Redis
REDIS_HOST_DEV=localhost
REDIS_PORT_DEV=6379
REDIS_PASSWORD_DEV=
REDIS_DB_DEV=0

# RabbitMQ
RABBITMQ_HOST_DEV=localhost
RABBITMQ_PORT_DEV=5672
RABBITMQ_USER_DEV=altese
RABBITMQ_PASS_DEV=senha-dev
RABBITMQ_VHOST_DEV=/
RABBITMQ_QUEUE_MESSAGES_DEV=altese-messages
RABBITMQ_QUEUE_AI_DEV=altese-ai-requests
RABBITMQ_QUEUE_NOTIFICATIONS_DEV=altese-notifications

# MinIO / Storage
MINIO_ENDPOINT_DEV=localhost
MINIO_PORT_DEV=9000
MINIO_USE_SSL_DEV=false
MINIO_ACCESS_KEY_DEV=minio-dev
MINIO_SECRET_KEY_DEV=minio-secret-dev
MINIO_BUCKET_ATTACHMENTS_DEV=attachments
MINIO_BUCKET_MEDIA_DEV=media
MINIO_BUCKET_LOGS_DEV=logs

# JWT
JWT_SECRET_DEV=jwt-secret-dev
JWT_EXPIRES_IN_DEV=1d
JWT_REFRESH_EXPIRES_IN_DEV=7d

# OpenAI
OPENAI_API_KEY_DEV=sua-openai-key-dev
OPENAI_TEMPERATURE_DEV=0.7
OPENAI_MAX_TOKENS_DEV=1000
OPENAI_TIMEOUT_DEV=30000

# Internal API / Qdrant
INTERNAL_API_KEY_DEV=internal-key-dev
QDRANT_PORT_DEV=6333

# WhatsApp
WHATSAPP_META_ACCESS_TOKEN_DEV=token-dev
WHATSAPP_META_VERIFY_TOKEN_DEV=verify-dev
WHATSAPP_UNOFFICIAL_SESSION_PATH=./sessions

# Security / CORS
CORS_ORIGIN_DEV=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Config
ATTENDANCE_INACTIVE_TIMEOUT=86400000
ATTENDANCE_CONTEXT_RETENTION_DAYS=7
AI_CONTEXT_TTL=604800
ROUTING_STRATEGY=round-robin
AFFINITY_RETENTION_DAYS=90
