# ============================================================
# AI Worker - Variáveis de ambiente (DESENVOLVIMENTO)
# ============================================================
# O ai-worker pode usar este arquivo ou config/local/credentials/.env
# ============================================================

# RabbitMQ (quando USE_SQS=false)
RABBITMQ_URL=amqp://altese:senha-dev@localhost:5672/

# PostgreSQL
POSTGRES_URL=postgresql://altese:senha-dev@localhost:5432/altese_autopecas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# OpenAI
OPENAI_API_KEY=sua-openai-key-dev
OPENAI_MODEL=gpt-4o-mini

# Node.js API (backend)
NODE_API_URL=http://localhost:3000
INTERNAL_API_KEY=internal-key-dev

# Custos (USD -> BRL)
USD_BRL_RATE=5.5

# SQS (produção) - manter false em dev
USE_SQS=false

# Logging
LOG_LEVEL=INFO
