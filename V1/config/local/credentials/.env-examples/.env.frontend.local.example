# ============================================================
# Frontend - Variáveis de ambiente (DESENVOLVIMENTO)
# ============================================================
# No Vite, use .env.development ou .env na pasta do frontend.
# Variáveis devem começar com VITE_
# ============================================================

# URL base da API (proxy dev ou caminho relativo)
# Para dev local: use caminho que o Vite faz proxy para o backend
VITE_API_URL=/api
